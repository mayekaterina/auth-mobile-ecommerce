<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Registration_Clean" targetNamespace="http://example.com/auth-mobile-ecommerce" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_Registration_Clean">
    <bpmn:participant id="Participant_User" name="Пользователь" />
    <bpmn:participant id="Participant_Mobile" name="Мобильное приложение" />
    <bpmn:participant id="Participant_Backend" name="Backend API" processRef="Process_Backend" />
    <bpmn:participant id="Participant_DB" name="База данных" />
    <bpmn:participant id="Participant_Email" name="Email сервис" />
    <bpmn:messageFlow id="Message_User_Mobile" name="Ввод email и пароля" sourceRef="Participant_User" targetRef="Participant_Mobile" />
    <bpmn:messageFlow id="Message_Mobile_Backend" name="POST /api/v1/auth/register" sourceRef="Participant_Mobile" targetRef="Start_Register_Request" />
    <bpmn:messageFlow id="Message_Weak_Mobile" name="400 WEAK_PASSWORD" sourceRef="Task_Return_Weak" targetRef="Participant_Mobile" />
    <bpmn:messageFlow id="Message_EmailExists_Mobile" name="409 EMAIL_ALREADY_EXISTS" sourceRef="Task_Return_Email_Exists" targetRef="Participant_Mobile" />
    <bpmn:messageFlow id="Message_Success_Mobile" name="201 CREATED" sourceRef="Task_Return_Success" targetRef="Participant_Mobile" />
    <bpmn:messageFlow id="Message_Check_Email_DB" name="Поиск пользователя по email" sourceRef="Task_Check_Email" targetRef="Participant_DB" />
    <bpmn:messageFlow id="Message_DB_Check_Result" name="Результат поиска" sourceRef="Participant_DB" targetRef="Task_Get_DB_Result" />
    <bpmn:messageFlow id="Message_Create_User_DB" name="Создать пользователя" sourceRef="Task_Create_User" targetRef="Participant_DB" />
    <bpmn:messageFlow id="Message_Send_Email" name="Отправить письмо подтверждения" sourceRef="Task_Send_Email" targetRef="Participant_Email" />
    <bpmn:messageFlow id="Message_Email_Result" name="Письмо отправлено" sourceRef="Participant_Email" targetRef="Task_Return_Success" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Backend" name="Регистрация пользователя" isExecutable="false">
    <bpmn:startEvent id="Start_Register_Request" name="Получен запрос регистрации">
      <bpmn:outgoing>Flow_Start_Validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Validate_Data" name="Проверить email и пароль">
      <bpmn:incoming>Flow_Start_Validate</bpmn:incoming>
      <bpmn:outgoing>Flow_Validate_Password_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Password_Strong" name="Пароль корректный?">
      <bpmn:incoming>Flow_Validate_Password_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Password_Weak</bpmn:outgoing>
      <bpmn:outgoing>Flow_Password_Strong</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Return_Weak" name="Вернуть ошибку слабого пароля">
      <bpmn:incoming>Flow_Password_Weak</bpmn:incoming>
      <bpmn:outgoing>Flow_Weak_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Weak" name="Регистрация не выполнена">
      <bpmn:incoming>Flow_Weak_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Check_Email" name="Запросить проверку email в БД">
      <bpmn:incoming>Flow_Password_Strong</bpmn:incoming>
      <bpmn:outgoing>Flow_Check_Email_Get_Result</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Get_DB_Result" name="Получить результат поиска">
      <bpmn:incoming>Flow_Check_Email_Get_Result</bpmn:incoming>
      <bpmn:outgoing>Flow_Get_Result_Email_Gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Email_Exists" name="Email найден?">
      <bpmn:incoming>Flow_Get_Result_Email_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Email_Exists</bpmn:outgoing>
      <bpmn:outgoing>Flow_Email_Free</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Return_Email_Exists" name="Вернуть ошибку email уже существует">
      <bpmn:incoming>Flow_Email_Exists</bpmn:incoming>
      <bpmn:outgoing>Flow_Email_Exists_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Email_Exists" name="Регистрация не выполнена">
      <bpmn:incoming>Flow_Email_Exists_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Hash_Password" name="Хешировать пароль">
      <bpmn:incoming>Flow_Email_Free</bpmn:incoming>
      <bpmn:outgoing>Flow_Hash_Create_User</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Create_User" name="Создать пользователя">
      <bpmn:incoming>Flow_Hash_Create_User</bpmn:incoming>
      <bpmn:outgoing>Flow_Create_Send_Email</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Send_Email" name="Запросить отправку письма">
      <bpmn:incoming>Flow_Create_Send_Email</bpmn:incoming>
      <bpmn:outgoing>Flow_Send_Email_Return_Success</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Return_Success" name="Вернуть успешный ответ">
      <bpmn:incoming>Flow_Send_Email_Return_Success</bpmn:incoming>
      <bpmn:outgoing>Flow_Success_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Success" name="Регистрация выполнена">
      <bpmn:incoming>Flow_Success_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Validate" sourceRef="Start_Register_Request" targetRef="Task_Validate_Data" />
    <bpmn:sequenceFlow id="Flow_Validate_Password_Gateway" sourceRef="Task_Validate_Data" targetRef="Gateway_Password_Strong" />
    <bpmn:sequenceFlow id="Flow_Password_Weak" name="Нет" sourceRef="Gateway_Password_Strong" targetRef="Task_Return_Weak" />
    <bpmn:sequenceFlow id="Flow_Password_Strong" name="Да" sourceRef="Gateway_Password_Strong" targetRef="Task_Check_Email" />
    <bpmn:sequenceFlow id="Flow_Weak_End" sourceRef="Task_Return_Weak" targetRef="End_Weak" />
    <bpmn:sequenceFlow id="Flow_Check_Email_Get_Result" sourceRef="Task_Check_Email" targetRef="Task_Get_DB_Result" />
    <bpmn:sequenceFlow id="Flow_Get_Result_Email_Gateway" sourceRef="Task_Get_DB_Result" targetRef="Gateway_Email_Exists" />
    <bpmn:sequenceFlow id="Flow_Email_Exists" name="Да" sourceRef="Gateway_Email_Exists" targetRef="Task_Return_Email_Exists" />
    <bpmn:sequenceFlow id="Flow_Email_Free" name="Нет" sourceRef="Gateway_Email_Exists" targetRef="Task_Hash_Password" />
    <bpmn:sequenceFlow id="Flow_Email_Exists_End" sourceRef="Task_Return_Email_Exists" targetRef="End_Email_Exists" />
    <bpmn:sequenceFlow id="Flow_Hash_Create_User" sourceRef="Task_Hash_Password" targetRef="Task_Create_User" />
    <bpmn:sequenceFlow id="Flow_Create_Send_Email" sourceRef="Task_Create_User" targetRef="Task_Send_Email" />
    <bpmn:sequenceFlow id="Flow_Send_Email_Return_Success" sourceRef="Task_Send_Email" targetRef="Task_Return_Success" />
    <bpmn:sequenceFlow id="Flow_Success_End" sourceRef="Task_Return_Success" targetRef="End_Success" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Registration_Clean">
    <bpmndi:BPMNPlane id="BPMNPlane_Registration_Clean" bpmnElement="Collaboration_Registration_Clean">
      <bpmndi:BPMNShape id="Participant_User_di" bpmnElement="Participant_User" isHorizontal="true">
        <dc:Bounds x="160" y="40" width="2300" height="80" />
