      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Email_Exists_di" bpmnElement="Flow_Email_Exists">
        <di:waypoint x="1235" y="485" />
        <di:waypoint x="1235" y="665" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1251" y="570" width="14" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Email_Free_di" bpmnElement="Flow_Email_Free">
        <di:waypoint x="1260" y="460" />
        <di:waypoint x="1350" y="460" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1301" y="437" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Email_Exists_End_di" bpmnElement="Flow_Email_Exists_End">
        <di:waypoint x="1340" y="700" />
        <di:waypoint x="1430" y="700" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Hash_Create_User_di" bpmnElement="Flow_Hash_Create_User">
